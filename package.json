{
  "name": "online_market",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint -c config/eslint.config.mjs",
    "docker:build": "docker build -f infra/docker/Dockerfile -t fluid-market:latest .",
    "docker:up": "docker compose --env-file .env.local -f infra/docker/docker-compose.yml up -d",
    "docker:logs": "docker compose --env-file .env.local -f infra/docker/docker-compose.yml logs -f app",
    "docker:down": "docker compose --env-file .env.local -f infra/docker/docker-compose.yml down"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
